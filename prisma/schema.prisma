// =============================================================================
// AI SYSTEM - MODELOS, ROLES, CONSUMO Y CUOTAS
// =============================================================================

//
// AI - PROVEEDORES (OpenAI, Anthropic, etc.)
//
enum AIProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  AZURE_OPENAI
  CUSTOM
}

//
// AI - MODELOS DISPONIBLES
//
model AIModel {
  id          String @id @default(cuid())

  provider    AIProvider
  modelId     String      // "gpt-4-turbo", "claude-3-opus", etc.
  name        String      // Nombre amigable: "GPT-4 Turbo"
  description String?

  // Costos por 1K tokens (en centavos USD)
  inputCostPer1k   Int @default(0)
  outputCostPer1k  Int @default(0)

  // Límites del modelo
  maxTokens        Int @default(4096)
  maxContextWindow Int @default(128000)

  // Configuración
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false)

  // Capacidades
  supportsVision    Boolean @default(false)
  supportsFunctions Boolean @default(true)
  supportsStreaming Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  roleAssignments AIRoleModel[]
  usageLogs       AIUsageLog[]

  @@unique([provider, modelId])
  @@index([isActive])
  @@index([provider])
}

//
// AI - ASISTENTES/PROMPTS POR CONTEXTO
//
model AIAssistant {
  id          String @id @default(cuid())

  name        String
  description String?
  slug        String @unique

  // Prompt del sistema
  systemPrompt    String
  welcomeMessage  String?

  // Configuración
  temperature     Float @default(0.7)
  maxTokens       Int   @default(2048)

  // Restricciones
  allowedContexts String[]

  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  roleAssignments AIRoleModel[]
  conversations   AIConversation[]

  @@index([isActive])
  @@index([slug])
}

//
// AI - CONFIGURACIÓN POR ROL
//
model AIRoleModel {
  id        String @id @default(cuid())

  role      Role

  modelId   String
  model     AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  assistantId String?
  assistant   AIAssistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  // Override del prompt para este rol
  customSystemPrompt String?

  // Límites específicos para este rol
  maxTokensPerRequest  Int?
  maxRequestsPerDay    Int?
  maxTokensPerDay      Int?
  maxTokensPerMonth    Int?

  isActive    Boolean @default(true)
  priority    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, modelId, assistantId])
  @@index([role])
  @@index([isActive])
}

//
// AI - CUOTAS DE USUARIO
//
model AIUserQuota {
  id        String @id @default(cuid())

  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Límites personalizados
  maxRequestsPerDay    Int?
  maxTokensPerDay      Int?
  maxTokensPerMonth    Int?
  maxCostPerMonth      Int?

  // Créditos adicionales
  bonusTokens          Int @default(0)
  bonusTokensExpireAt  DateTime?

  // Estado actual del período
  currentPeriodStart   DateTime @default(now())
  tokensUsedThisPeriod Int      @default(0)
  requestsToday        Int      @default(0)
  lastRequestAt        DateTime?

  // Bloqueos
  isBlocked       Boolean @default(false)
  blockedReason   String?
  blockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isBlocked])
}

//
// AI - CUOTAS GLOBALES DEL SISTEMA
//
model AISystemQuota {
  id        String @id @default(cuid())

  isActive  Boolean @default(true)

  // Límites globales diarios
  maxTotalRequestsPerDay  Int?
  maxTotalTokensPerDay    Int?
  maxTotalCostPerDay      Int?

  // Límites globales mensuales
  maxTotalTokensPerMonth  Int?
  maxTotalCostPerMonth    Int?

  // Alertas
  alertAtPercentage       Int @default(80)
  alertEmail              String?

  // Estado actual
  currentDayStart         DateTime @default(now())
  tokensUsedToday         Int      @default(0)
  requestsToday           Int      @default(0)
  costToday               Int      @default(0)

  currentMonthStart       DateTime @default(now())
  tokensUsedThisMonth     Int      @default(0)
  costThisMonth           Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

//
// AI - CONVERSACIONES
//
model AIConversation {
  id          String @id @default(cuid())

  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assistantId String?
  assistant   AIAssistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  // Contexto opcional
  contextType String?
  contextId   String?

  title       String?

  // Estadísticas
  messageCount     Int @default(0)
  totalTokensUsed  Int @default(0)
  totalCost        Int @default(0)

  isActive    Boolean @default(true)
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    AIMessage[]

  @@index([userId])
  @@index([assistantId])
  @@index([contextType, contextId])
  @@index([isActive])
}

//
// AI - MENSAJES DE CONVERSACIÓN
//
model AIMessage {
  id              String @id @default(cuid())

  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role            String
  content         String

  modelId         String?

  promptTokens    Int @default(0)
  completionTokens Int @default(0)
  totalTokens     Int @default(0)

  cost            Int @default(0)
  latencyMs       Int?

  metadata        Json?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

//
// AI - LOG DE USO
//
model AIUsageLog {
  id          String @id @default(cuid())

  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  modelId     String?
  model       AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  endpoint        String?
  requestType     String?

  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  cost            Int @default(0)
  latencyMs       Int?

  success         Boolean @default(true)
  errorMessage    String?

  conversationId  String?
  contextType     String?
  contextId       String?

  ipAddress       String?
  userAgent       String?
  metadata        Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([modelId])
  @@index([createdAt])
  @@index([success])
}

// =============================================================================
// SISTEMA DE LIQUIDACIÓN DE GASTOS ARBITRALES
// =============================================================================

//
// LIQUIDACIÓN DE GASTOS ARBITRALES (Documento maestro)
//
model CaseLiquidation {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Número de liquidación
  liquidationNumber   String @unique  // LIQ-001-2025-ARB/CAARD

  // Partes
  claimantName        String    // DTE (Demandante)
  respondentName      String    // DDO (Demandado)

  // Estado del proceso
  processStatus       String @default("EN_PROCESO") // EN_PROCESO, LAUDADO, CONCLUIDO
  awardDate           DateTime?  // Fecha del laudo

  // Gastos preliminares (Arancel por presentación)
  presentationFeeCents      Int @default(0)
  presentationFeeIgvCents   Int @default(0)
  presentationFeePaidAt     DateTime?
  presentationFeeInvoiceDate DateTime?

  // Totales calculados
  totalArbitratorFeesCents  Int @default(0)    // Total honorarios árbitros
  totalAdminFeesCents       Int @default(0)    // Total gastos administrativos
  totalIgvCents             Int @default(0)    // Total IGV
  grandTotalCents           Int @default(0)    // Gran total

  // Moneda
  currency            String @default("PEN")

  // Estado de la liquidación
  status              LiquidationStatus @default(DRAFT)

  // Auditoría
  createdById         String?
  approvedById        String?
  approvedAt          DateTime?

  // Notas
  notes               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  arbitratorFees      LiquidationArbitratorFee[]
  adminPayments       LiquidationAdminPayment[]
  installmentPlan     LiquidationInstallmentPlan?

  @@index([caseId])
  @@index([status])
}

enum LiquidationStatus {
  DRAFT           // Borrador
  PENDING_PAYMENT // Pendiente de pago
  PARTIAL_PAID    // Pago parcial
  PAID            // Pagado completamente
  CANCELLED       // Cancelado
}

//
// HONORARIOS DE ÁRBITROS EN LIQUIDACIÓN
// Un registro por cada árbitro en el caso
//
model LiquidationArbitratorFee {
  id              String @id @default(cuid())
  liquidationId   String
  liquidation     CaseLiquidation @relation(fields: [liquidationId], references: [id], onDelete: Cascade)

  // Árbitro
  arbitratorName  String    // Nombre del árbitro
  arbitratorId    String?   // Referencia a ArbitratorRegistry si existe

  // Montos netos (lo que recibe el árbitro)
  netAmountCents  Int       // Monto neto (sin retención)

  // Retención 4ta categoría (8%)
  retentionRate   Float @default(0.08)
  retentionCents  Int @default(0)

  // Monto bruto (neto + retención = lo que paga cada parte)
  grossAmountCents Int      // Monto bruto por parte

  // Estado de pago por parte (DTE = Demandante, DDO = Demandado)
  dteStatus       PaymentItemStatus @default(PENDING)
  dtePaidAt       DateTime?
  dteReceiptNumber String?   // R.H. (Recibo por Honorarios)
  dteReceiptDate   DateTime?

  ddoStatus       PaymentItemStatus @default(PENDING)
  ddoPaidAt       DateTime?
  ddoReceiptNumber String?
  ddoReceiptDate   DateTime?

  // Pago en vía de subrogación (cuando una parte paga por la otra)
  subrogationDte  Boolean @default(false)  // DTE pagó por DDO
  subrogationDdo  Boolean @default(false)  // DDO pagó por DTE
  subrogationDate DateTime?
  subrogationReceiptNumber String?
  subrogationReceiptDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([liquidationId])
  @@index([arbitratorId])
}

//
// GASTOS ADMINISTRATIVOS EN LIQUIDACIÓN
//
model LiquidationAdminPayment {
  id              String @id @default(cuid())
  liquidationId   String
  liquidation     CaseLiquidation @relation(fields: [liquidationId], references: [id], onDelete: Cascade)

  // Concepto
  concept         String    // "Gastos administrativos del centro", "Gastos por notificación física", etc.
  description     String?

  // Monto base (sin IGV)
  baseAmountCents Int

  // IGV (18%)
  igvRate         Float @default(0.18)
  igvCents        Int @default(0)

  // Total (base + IGV)
  totalCents      Int

  // A quién corresponde pagar
  payer           LiquidationPayer @default(DTE)

  // Estado de pago
  status          PaymentItemStatus @default(PENDING)
  paidAt          DateTime?
  invoiceNumber   String?   // F.E (Factura Emitida)
  invoiceDate     DateTime?

  // Pago en vía de subrogación
  subrogation     Boolean @default(false)
  subrogationBy   LiquidationPayer?
  subrogationDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([liquidationId])
  @@index([payer])
}

enum LiquidationPayer {
  DTE       // Demandante
  DDO       // Demandado
  BOTH      // Ambas partes (50/50)
  ARBITRO   // Árbitro (para pagos al árbitro)
}

enum PaymentItemStatus {
  PENDING         // Pendiente (P)
  PARTIAL         // Pago Parcial (P.P)
  PAID            // Pagado (verde)
  PENDING_CREDIT  // Falta Acreditar (F.A)
  INVOICE_ISSUED  // Factura Emitida (F.E)
  RECEIPT_ISSUED  // Recibo Emitido (R.E)
}

//
// PLAN DE FRACCIONAMIENTO EN LIQUIDACIÓN
//
model LiquidationInstallmentPlan {
  id              String @id @default(cuid())
  liquidationId   String @unique
  liquidation     CaseLiquidation @relation(fields: [liquidationId], references: [id], onDelete: Cascade)

  // Aprobación
  approvalMethod  String    // "Comunicación", "Resolución", etc.
  approvalRef     String?   // Número de comunicación/resolución
  approvalDate    DateTime?

  // Configuración
  numberOfInstallments Int

  // Cuotas
  installments    LiquidationInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiquidationInstallment {
  id        String @id @default(cuid())
  planId    String
  plan      LiquidationInstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Número de cuota
  installmentNumber Int   // 1, 2, 3, 4...

  // Honorarios arbitrales
  arbitratorFeeCents    Int @default(0)
  arbitratorRetentionCents Int @default(0)
  arbitratorReceiptNumber String?

  // Gastos administrativos
  adminFeeCents         Int @default(0)
  adminIgvCents         Int @default(0)
  adminInvoiceNumber    String?

  // Total de la cuota
  totalCents            Int

  // Estado
  status                PaymentItemStatus @default(PENDING)
  dueAt                 DateTime?
  paidAt                DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([installmentNumber])
}

// =============================================================================
// SISTEMA DE REGLAS - PAGOS, PLAZOS, ÁRBITROS, EMERGENCIA
// =============================================================================

//
// CONFIGURACIÓN DE TASAS Y ARANCELES
//
model FeeConfiguration {
  id        String @id @default(cuid())
  centerId  String

  code      String    // "PRESENTACION_NACIONAL", "EMERGENCIA", etc.
  name      String
  description String?

  scope     ArbitrationScope
  concept   PaymentConcept

