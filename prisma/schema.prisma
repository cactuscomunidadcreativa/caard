  centerId  String?

  code      String @unique
  name      String
  description String?

  // Disparador
  triggerType     String // "EVENT", "CRON", "STATE_CHANGE", "DEADLINE"
  triggerEvent    String?
  triggerCron     String?
  triggerFromState String?
  triggerToState  String?
  triggerDeadlineType String?

