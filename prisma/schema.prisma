  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([type])
  @@index([status])
  @@index([dueAt])
}

//
// HISTORIAL DE ETAPAS PROCESALES
//
model CaseStageHistory {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  fromStage     ProcessStage?
  toStage       ProcessStage
  fromStatus    CaseStatus?
  toStatus      CaseStatus

  reason        String?
  triggeredBy   String // "USER", "SYSTEM", "CRON", "ADMIN_OVERRIDE"
  userId        String?

  // Para devoluciones
  refundPercentage  Float?
  refundCalculated  Int?

  metadata      Json?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([toStage])
  @@index([createdAt])
}

//
// REGISTRO DE ÁRBITROS
//
model ArbitratorRegistry {
  id        String @id @default(cuid())
  centerId  String

  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    ArbitratorStatus @default(PENDING_APPROVAL)

  // Información profesional
  barNumber       String?
  barAssociation  String?
  specializations String[]

  // Fechas del registro
  applicationDate   DateTime @default(now())
  approvalDate      DateTime?
  suspensionDate    DateTime?
  suspensionEndDate DateTime?

  // Documentos
  ethicsDeclarationDocId  String?
  cvDocId                 String?
  independenceDocId       String?

  // Estadísticas
  casesAssigned     Int @default(0)
  casesCompleted    Int @default(0)
  casesInProgress   Int @default(0)
  recusationsReceived Int @default(0)
  sanctionsReceived   Int @default(0)

  // Configuración
  maxConcurrentCases  Int @default(10)
  acceptsEmergency    Boolean @default(true)

  // Notas internas
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  sanctions   ArbitratorSanction[]
  recusations Recusation[]
