  @@index([isPublished])
}

//
// CMS - SECCIONES (bloques de contenido en páginas)
//
enum CmsSectionType {
  // Secciones principales
  HERO           // Banner principal con imagen/video
  SLIDER         // Carrusel de banners
  BANNER         // Banner múltiple
  // Contenido
  TEXT           // Texto rico (markdown/HTML)
  CARDS          // Tarjetas (servicios, equipo, etc.)
  FEATURE_GRID   // Grid de características
  SPLIT_CONTENT  // Contenido dividido (imagen + texto)
  // Media
  VIDEO          // Video embebido (YouTube, Vimeo)
  GALLERY        // Galería de imágenes
  EMBED          // Contenido embebido (video, mapa)
  // Interactivo
  ACCORDION      // Preguntas frecuentes
  CTA            // Call to action
  STATS          // Estadísticas
  PRICING        // Tabla de precios
  // Personas
  TEAM           // Equipo/directivos
  TESTIMONIALS   // Testimonios
  // Formularios
  CONTACT_FORM   // Formulario de contacto
  DYNAMIC_FORM   // Formulario dinámico
  // Otros
  TIMELINE       // Línea de tiempo
  LOGO_CLOUD     // Logos de clientes/partners
  CUSTOM         // HTML personalizado
  // Módulos comerciales
  ARBITRATOR_PROFILES // Perfiles de árbitros destacados
  COURSE_CATALOG      // Catálogo de cursos embebido
  PRODUCT_CATALOG     // Catálogo de productos embebido
  LAUDO_FEATURED      // Laudos destacados
}

model CmsSection {
  id        String @id @default(cuid())
