//
// FRACCIONAMIENTO DE PAGOS
//
model PaymentInstallmentPlan {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Orden de pago original que se fracciona
  paymentOrderId  String

  // Solicitante
  requestedById   String
  requestedBy     User   @relation("InstallmentRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  requestedAt     DateTime @default(now())

  // Justificación del solicitante
  reason          String
  attachmentUrl   String?  // Documento de sustento opcional

  // Configuración del fraccionamiento
  totalAmountCents    Int      // Monto total a fraccionar
  numberOfInstallments Int     // Número de cuotas (2-12)
  installmentAmountCents Int   // Monto por cuota

  // Estado de aprobación
  status          InstallmentPlanStatus @default(PENDING)

  // Aprobación/Rechazo por admin
  reviewedById    String?
  reviewedBy      User?   @relation("InstallmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  reviewNotes     String?  // Notas del admin
  rejectionReason String?  // Si fue rechazado

  // Fechas del plan
  firstDueDate    DateTime  // Fecha de vencimiento primera cuota

  // Cuotas individuales
  installments    PaymentInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([requestedById])
  @@index([paymentOrderId])
}

model PaymentInstallment {
  id        String @id @default(cuid())
  planId    String
  plan      PaymentInstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Número de cuota
  installmentNumber Int  // 1, 2, 3...

  // Monto
  amountCents       Int
  currency          String @default("PEN")

  // Fechas
  dueAt             DateTime
  paidAt            DateTime?

  // Estado
  status            PaymentInstallmentStatus @default(PENDING)

  // Pago asociado (cuando se paga)
  paymentId         String?

  // Voucher (para pago manual)
  voucherUrl        String?
  voucherVerifiedAt DateTime?
  voucherVerifiedById String?

  // Recargo por mora (si aplica)
  lateFeeApplied    Boolean @default(false)
  lateFeeCents      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([status])
  @@index([dueAt])
}

enum InstallmentPlanStatus {
  PENDING      // Pendiente de aprobación
  APPROVED     // Aprobado por admin
  REJECTED     // Rechazado por admin
  ACTIVE       // En curso (ya tiene cuotas programadas)
  COMPLETED    // Todas las cuotas pagadas
  DEFAULTED    // Incumplido (cuotas vencidas sin pagar)
  CANCELLED    // Cancelado
}

enum PaymentInstallmentStatus {
  PENDING      // Pendiente de pago
  PAID         // Pagado
  OVERDUE      // Vencido sin pagar
  CANCELLED    // Cancelado
}

//
// PLAZOS PROCESALES
//
model ProcessDeadline {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type          DeadlineType
  title         String
  description   String?

  // Cálculo
  startsAt      DateTime
  businessDays  Int
  dueAt         DateTime
  timezone      String @default("America/Lima")

  // Estado
  status        DeadlineStatus @default(ACTIVE)
  completedAt   DateTime?

  // Consecuencias
  onOverdueAction   String? // "SUSPEND", "ARCHIVE", "NOTIFY", "ESCALATE"
  changeStateTo     CaseStatus?
  notifyRoles       String[] // ["SECRETARIA", "ADMIN"]

  // Extensiones
  originalDueAt     DateTime?
  extensionReason   String?
  extendedById      String?
  extendedAt        DateTime?

  // Recordatorios enviados
  reminder3DaysSent   Boolean @default(false)
  reminder1DaySent    Boolean @default(false)
  reminderOverdueSent Boolean @default(false)

