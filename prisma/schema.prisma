// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  SUPER_ADMIN     // Administrador del sistema completo
  ADMIN           // Administrador general del centro
  CENTER_STAFF    // Personal del centro (staff administrativo)
  SECRETARIA      // Secretaría arbitral
  ARBITRO         // Árbitro
  ABOGADO         // Abogado (puede representar demandantes o demandados)
  DEMANDANTE      // Parte demandante
  DEMANDADO       // Parte demandada
  ESTUDIANTE      // Estudiante (cursos, tienda, consulta básica)
}

enum CaseStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  OBSERVED
  ADMITTED
  REJECTED
  IN_PROCESS
  AWAITING_PAYMENT
  PAYMENT_OVERDUE
  SUSPENDED
  CLOSED
  ARCHIVED
  // Estados de emergencia
  EMERGENCY_REQUESTED
  EMERGENCY_IN_PROCESS
  EMERGENCY_RESOLVED
  EMERGENCY_EXPIRED
}

enum ArbitrationScope {
  NACIONAL
  INTERNACIONAL
}

enum ProcedureType {
  REGULAR
  EMERGENCY
}

enum ProcessStage {
  DEMANDA
  CONTESTACION
  RECONVENCION
  PROBATORIA
  AUDIENCIA_PRUEBAS
  INFORMES_ORALES
  LAUDO
}

enum DeadlineType {
  PAYMENT
  CONTESTACION
  RECONVENCION
  CONTESTACION_RECONVENCION
  ALEGATOS
  RECUSACION_ABSOLUCION
  DESIGNACION_ARBITRO
  SUBSANACION
  EMERGENCY_VERIFICATION
  EMERGENCY_PAYMENT
  EMERGENCY_DESIGNATION
  EMERGENCY_RESOLUTION
  EMERGENCY_PRINCIPAL_REQUEST
  CUSTOM
}

enum DeadlineStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
  EXTENDED
}

enum PaymentOrderStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentConcept {
  TASA_PRESENTACION
  GASTOS_ADMINISTRATIVOS
  HONORARIOS_ARBITRO_UNICO
  HONORARIOS_TRIBUNAL
  TASA_EMERGENCIA
  GASTOS_RECONVENCION
  RELIQUIDACION
  OTROS
}

enum ArbitratorStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  SANCTIONED
  RETIRED
  REJECTED
}

enum EmergencyStatus {
  REQUESTED
  PENDING_VERIFICATION
  VERIFICATION_FAILED
  PENDING_PAYMENT
  PAYMENT_OVERDUE
  PENDING_DESIGNATION
  DESIGNATION_OVERDUE
  PENDING_ACCEPTANCE
  IN_PROCESS
  RESOLVED
  PENDING_MAIN_CASE
  COMPLETED
  EXPIRED
  ARCHIVED
}

enum RecusationStatus {
  FILED
  TRANSFERRED
  PENDING_RESPONSE
  RESPONSE_RECEIVED
  PENDING_COUNCIL_DECISION
  ACCEPTED
  REJECTED
}

enum SanctionType {
  WARNING
  SUSPENSION
  REMOVAL
}

enum ArbitrationKind {
  INSTITUTIONAL
  AD_HOC
}

enum TribunalMode {
  SOLE_ARBITRATOR
  TRIBUNAL_3
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationEventType {
  // Solicitud / Admisión
  CASE_SUBMITTED
  CASE_OBSERVED
  CASE_ADMITTED
  CASE_REJECTED

  // Documentos
  DOCUMENT_UPLOADED
  DOCUMENT_REPLACED

  // Plazos
  DEADLINE_UPCOMING
  DEADLINE_OVERDUE

  // Audiencias
  HEARING_SCHEDULED
  HEARING_UPDATED
  HEARING_REMINDER

  // Pagos
  PAYMENT_REQUIRED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_OVERDUE

  // Laudo / Cierre
  AWARD_ISSUED
  CASE_CLOSED
}

enum NotificationStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum PaymentProvider {
  CULQI
  MANUAL_VOUCHER
}

enum PaymentStatus {
  REQUIRED
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
  OVERDUE
  REFUNDED
}

enum DocumentStatus {
  ACTIVE
  REPLACED
  VOID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  DOWNLOAD
  LOGIN
  LOGOUT
  SEND_NOTIFICATION
  PAYMENT_UPDATE
  CASE_STATUS_CHANGE
  // User management actions
  UPDATE_PROFILE
  CHANGE_PASSWORD
  CREATE_USER
  UPDATE_USER
  DEACTIVATE_USER
  UPDATE_NOTIFICATION_PREFERENCES
}

//
// CORE MULTI-CENTER
//

model Center {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "CAARD"
  name        String
  legalName   String?
  taxId       String?

  // Google Drive root (Shared Drive / folder ids)
  driveRootFolderId   String?
  driveSharedDriveId  String?

  // Branding / UI tokens (opcional, para multi-centro)
  primaryColorHex     String? // e.g., "#0B2A5B"
  accentColorHex      String? // e.g., "#D66829"
  neutralColorHex     String? // e.g., "#9A9A9E"

  // Configuracion de notificaciones (Email, SMS, WhatsApp)
  notificationSettings Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  arbitrationTypes ArbitrationType[]
  users            User[]
  cases            Case[]
  auditLogs        AuditLog[]

  // CMS Relations
  cmsPages         CmsPage[]
  cmsMenuItems     CmsMenuItem[]
  cmsArticles      CmsArticle[]
  cmsCategories    CmsCategory[]
  cmsEvents        CmsEvent[]
  cmsAnnouncements CmsAnnouncement[]
  cmsMedia         CmsMedia[]
  cmsSiteConfig    CmsSiteConfig?

  // Commerce Relations
  courses          Course[]
  storeProducts    StoreProduct[]
  storeCategories  StoreCategory[]
  storeOrders      StoreOrder[]
  carts            Cart[]
  commerceTaxConfigs CommerceTaxConfig[]
  freePayments     FreePayment[]
  laudos           Laudo[]
  laudoCategories  LaudoCategory[]
  laudoPackages    LaudoPackage[]
  landingPages     LandingPage[]
}

//
// AUTH + USERS
//

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  phoneE164    String?  // +51...
  passwordHash String?  // For credentials auth

  role      Role     @default(DEMANDANTE)
  isActive  Boolean  @default(true)

  centerId  String?
  center    Center?  @relation(fields: [centerId], references: [id], onDelete: SetNull)

  // NextAuth standard tables relation
  accounts  Account[]
  sessions  Session[]

  // Relations
  caseMemberships CaseMember[]
  lawyerCases     CaseLawyer[]   @relation("LawyerCases") // Casos donde actúa como abogado
  documents       CaseDocument[] @relation("UploadedDocuments")
  auditLogs       AuditLog[]
  notifications   NotificationQueue[]
  caseNotes       CaseNote[]

  // CMS Relations
  cmsArticles     CmsArticle[]
  cmsMedia        CmsMedia[]

  // User Preferences
  notificationPreference NotificationPreference?

  // AI Relations
  aiQuota         AIUserQuota?
  aiConversations AIConversation[]
  aiUsageLogs     AIUsageLog[]

  // Fraccionamiento de pagos
  installmentRequests  PaymentInstallmentPlan[] @relation("InstallmentRequester")
  installmentReviews   PaymentInstallmentPlan[] @relation("InstallmentReviewer")

  // Árbitros
  arbitratorRegistry   ArbitratorRegistry?

  // Notificaciones in-app
  inAppNotifications   Notification[]

  // System integrations
  organizedMeetings    ScheduledMeeting[] @relation("MeetingOrganizer")
  meetingParticipations MeetingParticipant[]
  systemAuditLogs      SystemAuditLog[]

  // OTP tokens
  otpTokens            OtpToken[]

  // Commerce Relations
  enrollments          Enrollment[]
  storeOrders          StoreOrder[]
  cart                 Cart?
  freePayments         FreePayment[]
  laudoSubscriptions   LaudoSubscription[]
  laudoAccesses        LaudoAccess[]

  // 2FA settings
  twoFactorEnabled     Boolean @default(false)
  twoFactorChannel     String? // EMAIL, SMS, WHATSAPP
  phone                String? // Número de teléfono para SMS/WhatsApp

  // Email verification
  emailVerified        DateTime?  // Fecha de verificación del email
  emailVerificationToken String?  // Token temporal para verificación

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([role])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//
// OTP - One Time Password para autenticación de dos factores
//
model OtpToken {
  id        String @id @default(cuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String    // Código OTP (6 dígitos)
  type      OtpType   // LOGIN, PASSWORD_RESET, VERIFICATION
  channel   OtpChannel // EMAIL, SMS, WHATSAPP

  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0) // Intentos fallidos

  // Metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code, type])
  @@index([expiresAt])
}

enum OtpType {
  LOGIN
  PASSWORD_RESET
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  ACTION_CONFIRMATION
}

enum OtpChannel {
  EMAIL
  SMS
  WHATSAPP
}

//
// ROLE CONFIG - Configuración dinámica de roles
//
model RoleConfig {
  id          String @id @default(cuid())

  role        Role   @unique
  displayName String          // Nombre para mostrar: "Administrador General"
  description String?         // Descripción del rol
  color       String?         // Color para badges: "bg-red-100 text-red-700"
  icon        String?         // Icono lucide: "Shield", "User", etc.

  // Permisos generales
  permissions Json?           // Array de permisos: ["users.create", "cases.view", etc.]

  // Configuración de acceso
  canAccessAdmin      Boolean @default(false)
  canAccessCMS        Boolean @default(false)
  canAccessAI         Boolean @default(false)
  canManageUsers      Boolean @default(false)
  canManageCases      Boolean @default(false)
  canManageDocuments  Boolean @default(false)
  canViewReports      Boolean @default(false)

  // Límites
  maxCasesAssigned    Int?    // Máximo de casos asignados (para árbitros, abogados)

  // Estado
  isActive            Boolean @default(true)
  isSystemRole        Boolean @default(false) // Roles del sistema no se pueden eliminar

  sortOrder           Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

//
// ARBITRATION TYPE CONFIG (per Center)
//

model ArbitrationType {
  id           String @id @default(cuid())
  centerId     String
  center       Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  code         String // e.g., "COMERCIAL", "CONSTRUCCION", "EMERGENCIA"
  name         String
  description  String?
  kind         ArbitrationKind @default(INSTITUTIONAL)
  tribunalMode TribunalMode    @default(SOLE_ARBITRATOR)

  // Notification rules & templates per type
  notificationRules NotificationRule[]

  // Pricing config (simple v1)
  baseFeeCents     Int? // e.g., 50000 = 500.00
  currency         String @default("PEN")

  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cases Case[]

  @@unique([centerId, code])
  @@index([centerId])
}

//
// CASE / EXPEDIENTE
//

model Case {
  id              String @id @default(cuid())
  centerId        String
  center          Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  arbitrationTypeId String
  arbitrationType   ArbitrationType @relation(fields: [arbitrationTypeId], references: [id], onDelete: Restrict)

  // Correlative code: EXP-2026-CAARD-000123
  year           Int
  sequence       Int
  code           String @unique

  title          String?
  status         CaseStatus @default(SUBMITTED)

  // Scope and procedure type
  scope          ArbitrationScope @default(NACIONAL)
  procedureType  ProcedureType    @default(REGULAR)
  tribunalMode   TribunalMode     @default(SOLE_ARBITRATOR)

  // Current process stage
  currentStage   ProcessStage?

  // Blocking control
  isBlocked      Boolean @default(false)
  blockReason    String?
  blockedAt      DateTime?
  blockedBy      String?

  // Dispute amount (for fee calculation)
  disputeAmountCents BigInt?
  currency           String @default("PEN")

  // Datos administrativos (LISTA DE EXPEDIENTES ARBITRALES)
  durationDays       Int?
  durationText       String?
  hasCouncil         Boolean?
  centerFeeCents     BigInt?   // GASTOS DEL CENTRO
  taxCents           BigInt?   // TASA
  totalAdminFeeCents BigInt?   // TOTAL DE TASA ADMINISTRATIVA
  relatedMainCaseCode String?  // Para ARBEMEs: proceso principal asociado

  // Parties summary (canonical; detailed in CaseMember)
  claimantName   String?
  respondentName String?

  // Drive folder root for expediente
  driveFolderId  String?
  driveFolderPath String? // optional cached display path

  submittedAt    DateTime?
  admittedAt     DateTime?
  closedAt       DateTime?

  // Relations
  members     CaseMember[]
  lawyers     CaseLawyer[]   // Abogados asignados al caso
  folders     CaseFolder[]
  documents   CaseDocument[]
  deadlines   CaseDeadline[]
  hearings    CaseHearing[]
  payments    Payment[]
  notes       CaseNote[]
  auditLogs   AuditLog[]
  notifications NotificationQueue[]

  // New rules system relations
  paymentOrders     PaymentOrder[]
  processDeadlines  ProcessDeadline[]
  stageHistory      CaseStageHistory[]
  emergencyRequests EmergencyRequest[]
  recusations       Recusation[]
  installmentPlans  PaymentInstallmentPlan[]

  // Liquidación de gastos
  liquidations      CaseLiquidation[]

  // Reuniones programadas
  scheduledMeetings ScheduledMeeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId, year, sequence])
  @@index([centerId, status])
  @@index([arbitrationTypeId])
  @@index([isBlocked])
  @@index([currentStage])
}

model CaseMember {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  role      Role   // DEMANDANTE / DEMANDADO / ARBITRO / SECRETARIA (por caso)
  displayName String?
  email      String?
  phoneE164  String?

  isPrimary  Boolean @default(false) // p.ej., representante principal
  createdAt  DateTime @default(now())

  // Relación con abogados que representan a este miembro
  lawyerRepresentations CaseLawyer[] @relation("RepresentedMember")

  @@index([caseId])
  @@index([userId])
  @@index([caseId, role])
}

//
// ABOGADOS EN CASOS
// Vincula abogados con casos y las partes que representan
//
model CaseLawyer {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  lawyerId  String
  lawyer    User   @relation("LawyerCases", fields: [lawyerId], references: [id], onDelete: Cascade)

  // A quién representa en este caso
  representedMemberId String?
  representedMember   CaseMember? @relation("RepresentedMember", fields: [representedMemberId], references: [id], onDelete: SetNull)

  // Tipo de representación
  representationType  LawyerRepresentationType @default(DEMANDANTE)

  // Información adicional
  caseNumber          String?   // Número de colegiatura
  barAssociation      String?   // Colegio de Abogados
  powerOfAttorneyDoc  String?   // Referencia al documento de poder

  // Estado
  isActive            Boolean @default(true)
  isLead              Boolean @default(false) // Abogado principal
  authorizedAt        DateTime?
  revokedAt           DateTime?

  // Metadata
  notes               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([caseId, lawyerId, representationType])
  @@index([caseId])
  @@index([lawyerId])
  @@index([representedMemberId])
  @@index([representationType])
}

enum LawyerRepresentationType {
  DEMANDANTE  // Representa al demandante
  DEMANDADO   // Representa al demandado
  AMBOS       // Representa a ambas partes (casos especiales)
}

//
// FOLDERS + DOCUMENTS (Google Drive-backed)
//

model CaseFolder {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  key       String // "01_Solicitud", "02_Admisión", etc.
  name      String
  parentId  String?
  parent    CaseFolder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  CaseFolder[] @relation("FolderTree")

  // Drive mapping
  driveFolderId String?
  drivePath     String?

  documents CaseDocument[]

  createdAt DateTime @default(now())

  @@unique([caseId, key])
  @@index([caseId])
  @@index([parentId])
}

model CaseDocument {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  folderId  String?
  folder    CaseFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  uploadedById String?
  uploadedBy   User? @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Classification
  documentType String // "Demanda", "Contestación", "Prueba", ...
  description  String?

  // File meta
  originalFileName String
  storedFileName   String? // sanitized
  mimeType         String
  sizeBytes        BigInt
  checksumSha256   String?

  // Drive pointers (source of truth)
  driveFileId      String
  driveWebViewLink String?
  driveDownloadLink String?

  // Versioning
  version     Int @default(1)
  status      DocumentStatus @default(ACTIVE)
  replacedById String?
  replacedBy   CaseDocument? @relation("DocReplace", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces     CaseDocument[] @relation("DocReplace")

  // Payment voucher relation
  paymentVouchers Payment[]

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([folderId])
  @@index([uploadedById])
  @@index([driveFileId])
  @@index([caseId, documentType])
}

//
// DEADLINES / PLAZOS
//

model CaseDeadline {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  title     String
  description String?
  dueAt     DateTime
  timezone  String @default("America/Lima")

  isCompleted Boolean @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([dueAt])
  @@index([caseId, isCompleted])
}

//
// HEARINGS / AUDIENCIAS
//

model CaseHearing {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  title     String
  hearingAt DateTime
  timezone  String @default("America/Lima")
  location  String?
  meetingUrl String?

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([hearingAt])
}

//
// PAYMENTS (Culqi + manual voucher)
//

model Payment {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  provider  PaymentProvider @default(CULQI)
  status    PaymentStatus   @default(PENDING)

  currency  String @default("PEN")
  amountCents Int

  concept   String // "Tasa arbitral", "Honorarios", etc.
  description String?

  // Culqi references
  culqiChargeId String?
  culqiOrderId  String?
  culqiPaymentMethod String?
  culqiRaw      Json?

  // Manual voucher
  voucherDocumentId String?
  voucherDocument   CaseDocument? @relation(fields: [voucherDocumentId], references: [id], onDelete: SetNull)

  dueAt     DateTime?
  paidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([provider])
}

//
// NOTES / INTERNAL COMMENTS (optional but useful)
//

model CaseNote {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  authorId  String?
  author    User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  title     String?
  content   String

  isPrivate Boolean @default(true) // visible only to secretaría/admin, configurable

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([authorId])
}

//
// NOTIFICATIONS ENGINE
//

model NotificationRule {
  id        String @id @default(cuid())
  arbitrationTypeId String
  arbitrationType   ArbitrationType @relation(fields: [arbitrationTypeId], references: [id], onDelete: Cascade)

  eventType  NotificationEventType
  channel    NotificationChannel

  // who gets it (by case roles)
  // e.g. ["DEMANDANTE","DEMANDADO","SECRETARIA"]
  targetRoles Role[]

  // template keys (resolved in app layer)
  templateKey String
  subjectTemplate String?
  bodyTemplate    String? // store text/html or key only

  // scheduling rules
  // e.g. for deadline reminders: {"hoursBefore": 48}
  ruleConfig Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arbitrationTypeId])
  @@index([eventType])
}

model NotificationQueue {
  id        String @id @default(cuid())

  caseId    String?
  case      Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  channel   NotificationChannel
  eventType NotificationEventType
  status    NotificationStatus @default(QUEUED)

  toEmail   String?
  toPhoneE164 String?

  subject   String?
  body      String?

  providerMessageId String?
  providerResponse  Json?

  errorMessage String?

  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([eventType])
  @@index([caseId])
  @@index([userId])
}

//
// NOTIFICACIONES IN-APP (para el usuario)
//
model Notification {
  id        String @id @default(cuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "PAYMENT", "CASE", "DEADLINE", "SYSTEM"
  title     String
  message   String
  metadata  Json?

  isRead    Boolean @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

//
// AUDIT LOG
//

model AuditLog {
  id        String @id @default(cuid())

  centerId  String?
  center    Center? @relation(fields: [centerId], references: [id], onDelete: SetNull)

  caseId    String?
  case      Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    AuditAction
  entity    String // "Case", "CaseDocument", "Payment", ...
  entityId  String?
  meta      Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([centerId])
  @@index([caseId])
  @@index([userId])
  @@index([action])
}

// =============================================================================
// CMS - CONTENT MANAGEMENT SYSTEM
// =============================================================================

//
// CMS - PÁGINAS
//
model CmsPage {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug      String // "inicio", "el-centro", "arbitraje"
  title     String
