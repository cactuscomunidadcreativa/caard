//
// CMS - CATEGORÍAS (para artículos y eventos)
//
model CmsCategory {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug      String
  name      String
  description String?
  color     String?

  articles  CmsArticle[]
  events    CmsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
}

//
// CMS - EVENTOS
//
enum CmsEventType {
  WEBINAR
  CONFERENCE
  WORKSHOP
  COURSE
  SEMINAR
  OTHER
}

model CmsEvent {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug      String
  title     String
  description String?
  content   String?       // Contenido completo
