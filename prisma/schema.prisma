//
// CMS - AVISOS/ANUNCIOS
//
enum CmsAnnouncementType {
  INFO
  WARNING
  SUCCESS
  ERROR
  NEWS
}

// Formato de visualización del anuncio
enum CmsAnnouncementDisplayFormat {
  BANNER        // Barra superior simple
  POPUP         // Popup pequeño (esquina)
  MODAL         // Modal central grande
  FULLSCREEN    // Modal a pantalla completa
  FLOATING      // Flotante en esquina (tipo ad)
}

model CmsAnnouncement {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

