//
// SANCIONES A ÁRBITROS
//
model ArbitratorSanction {
  id        String @id @default(cuid())

  arbitratorId    String
  arbitrator      ArbitratorRegistry @relation(fields: [arbitratorId], references: [id], onDelete: Cascade)

  type            SanctionType
  reason          String
  resolutionNumber String?

  // Duración
  startDate       DateTime
  endDate         DateTime?

  // Impacto
  blocksNewAssignments    Boolean @default(true)
  removesFromActiveCases  Boolean @default(false)

  // Auditoría
  issuedById      String?
  appealedAt      DateTime?
  appealResult    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arbitratorId])
  @@index([type])
  @@index([startDate])
}

//
// RECUSACIONES
//
model Recusation {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

