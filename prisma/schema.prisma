  // Estilo y configuración
  bgColor   String? // Color de fondo
  textColor String?
  bgImage   String? // URL de imagen de fondo
  padding   String? // "sm", "md", "lg", "xl"

  sortOrder Int @default(0)
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([sortOrder])
}

//
// CMS - MENÚ DE NAVEGACIÓN
//
model CmsMenuItem {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    CmsMenuItem?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
