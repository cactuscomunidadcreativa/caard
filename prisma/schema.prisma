  refundPercentage Float
  retainedPercentage Float

  description     String?
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, stage])
  @@index([centerId])
  @@index([stage])
