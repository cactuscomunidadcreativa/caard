  filedAt         DateTime @default(now())
  transferredAt   DateTime?
  responseDueAt   DateTime?
  arbitratorResponseAt DateTime?
  resolvedAt      DateTime?

  // Respuestas
  arbitratorResponse  String?
  otherPartyResponse  String?

  // Resolución del Consejo
  councilDecision     String? // "ACCEPTED", "REJECTED"
  councilResolution   String?
  resolvedById        String?

  metadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([arbitratorId])
  @@index([status])
