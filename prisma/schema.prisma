//
// INTERVENCIONES ADMINISTRATIVAS (Admin Override Log)
//
model AdminIntervention {
  id        String @id @default(cuid())
  centerId  String?

  // Quién y qué
  adminUserId     String
  action          String // "FORCE_STATE_CHANGE", "UNBLOCK_CASE", "EXTEND_DEADLINE", etc.
  targetEntity    String // "Case", "PaymentOrder", "Deadline", etc.
  targetEntityId  String

  // Justificación (requerida)
  justification   String
  resolutionNumber String?

  // Valores
  previousValue   Json?
  newValue        Json?

  // Aprobación (para acciones críticas)
  requiresApproval Boolean @default(false)
  approvedById     String?
  approvedAt       DateTime?

  metadata        Json?

  createdAt DateTime @default(now())

  @@index([centerId])
  @@index([adminUserId])
  @@index([action])
  @@index([targetEntity])
  @@index([createdAt])
}

// =============================================================================
// SISTEMA DE IMPUESTOS - PERÚ
// =============================================================================

//
// TIPOS DE IMPUESTO PERUANO
//
enum TaxType {
  IGV               // Impuesto General a las Ventas (18%)
  DETRACCION        // Detracción SPOT (12% servicios > S/. 700)
  PERCEPCION        // Percepción del IGV
  RETENCION_4TA     // Retención 4ta Categoría (8% honorarios > S/. 1,500)
  RETENCION_IGV     // Retención de IGV (agentes designados)
  IR                // Impuesto a la Renta
  EXONERADO         // Exonerado de impuestos
}

//
// CONFIGURACIÓN DE IMPUESTOS
//
model TaxConfiguration {
  id        String @id @default(cuid())
  centerId  String

  // Tipo de impuesto
  taxType       TaxType
  code          String    // "IGV_18", "DETRACCION_12", "RETENCION_4TA_8"
  name          String    // "IGV 18%", "Detracción SPOT 12%"
  description   String?

  // Tasas
  rate          Float     // 0.18 para 18%, 0.12 para 12%, 0.08 para 8%

  // Umbrales de aplicación (en céntimos)
  minimumAmountCents  Int?    // Monto mínimo para aplicar (ej: 70000 = S/. 700 para detracción)
  currency            String @default("PEN")

  // Configuración específica
  appliesTo           String[]  // ["INSTITUCIONAL", "ARBITRO_PERSONA_NATURAL", "ARBITRO_PERSONA_JURIDICA"]

  // Cuenta bancaria para detracciones (Banco de la Nación)
  detractionAccountNumber String?  // Cuenta de detracciones
  detractionBankCode      String?  // Código del banco

  // Referencias normativas
  legalBasis        String?   // "TUO IGV - D.S. 055-99-EF", "D.Leg. 940 - SPOT"
  sunatCode         String?   // Código SUNAT si aplica

  // Estado
  isActive          Boolean @default(true)
  effectiveFrom     DateTime @default(now())
  effectiveUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, code])
  @@index([centerId])
  @@index([taxType])
  @@index([isActive])
}

//
// TIPO DE CONTRIBUYENTE
//
enum TaxpayerType {
  PERSONA_NATURAL       // Persona natural (RUC 10)
  PERSONA_JURIDICA      // Empresa (RUC 20)
  NO_DOMICILIADO        // No domiciliado en Perú
}

//
// PAGOS A ÁRBITROS
//
model ArbitratorPayment {
  id        String @id @default(cuid())
  centerId  String

  // Caso y árbitro
  caseId            String
  arbitratorId      String    // ArbitratorRegistry.id
  arbitratorUserId  String    // User.id del árbitro

  // Concepto del pago
  concept           String    // "HONORARIOS_CASO", "HONORARIOS_EMERGENCIA"
  description       String?

  // Tipo de contribuyente del árbitro
  taxpayerType      TaxpayerType @default(PERSONA_NATURAL)
  arbitratorRuc     String?   // RUC del árbitro

  // Montos brutos (en céntimos)
  grossAmountCents      Int       // Monto bruto total
  currency              String @default("PEN")

  // Impuestos calculados
  // Para persona natural: NO aplica IGV, SÍ aplica retención 4ta
  // Para persona jurídica: SÍ aplica IGV si corresponde
  igvCents              Int @default(0)     // IGV si es persona jurídica
  igvRate               Float @default(0)   // Tasa IGV aplicada

  // Retención 4ta categoría (8% sobre honorarios > S/. 1,500)
  retencion4taCents     Int @default(0)     // Monto de retención
  retencion4taRate      Float @default(0)   // Tasa aplicada (0.08)
  retencion4taApplied   Boolean @default(false)

  // Detracción (si aplica - usualmente para servicios > S/. 700)
  detractionCents       Int @default(0)
  detractionRate        Float @default(0)   // 0.12 = 12%
  detractionApplied     Boolean @default(false)
  detractionNumber      String?   // Número de constancia de detracción

  // Cálculos finales
  totalDeductionsCents  Int @default(0)     // Total de deducciones
  netPaymentCents       Int       // Monto neto a pagar al árbitro

  // Estado del pago
  status            PaymentStatus @default(PENDING)

  // Fechas
  issuedAt          DateTime @default(now())
  dueAt             DateTime?
  paidAt            DateTime?

  // Comprobante de pago (voucher o transferencia)
  paymentMethod     String?   // "TRANSFERENCIA", "CHEQUE"
  bankAccountNumber String?   // Cuenta del árbitro
  bankName          String?
  transactionRef    String?   // Referencia de la transferencia
  voucherUrl        String?   // Comprobante adjunto

  // Recibo por honorarios
  reciboHonorariosNumber  String?   // Número del recibo emitido por el árbitro
  reciboHonorariosDate    DateTime?
  reciboHonorariosUrl     String?   // PDF del recibo

  // Auditoría
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  processedById     String?
  processedAt       DateTime?

  // Metadata
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([caseId])
  @@index([arbitratorId])
  @@index([status])
  @@index([taxpayerType])
}

//
// CONFIRMACIÓN DE PAGOS RECIBIDOS
//
model PaymentConfirmation {
  id        String @id @default(cuid())
  centerId  String

  // Tipo de pago confirmado
  paymentType       String    // "PAYMENT_ORDER", "INSTALLMENT", "FEE"
  paymentOrderId    String?   // Referencia a PaymentOrder si aplica
  installmentId     String?   // Referencia a PaymentInstallment si aplica

  // Información del pagador
  payerName         String
  payerRuc          String?
  payerEmail        String?

  // Montos
  expectedAmountCents   Int       // Monto esperado
  receivedAmountCents   Int       // Monto realmente recibido
  currency              String @default("PEN")

  // Diferencia (si hay)
  differenceType        String?   // "EXACT", "OVERPAYMENT", "UNDERPAYMENT"
  differenceCents       Int @default(0)
  differenceReason      String?

  // Datos del depósito/transferencia
  paymentMethod         String    // "TRANSFERENCIA", "DEPOSITO", "ONLINE", "CHEQUE"
  bankName              String?
  accountNumber         String?   // Cuenta donde se depositó
  transactionDate       DateTime
  transactionRef        String?   // Número de operación

  // Voucher
  voucherUrl            String?
  voucherVerified       Boolean @default(false)
  voucherVerifiedAt     DateTime?
  voucherVerifiedById   String?

  // Impuestos asociados (si aplica)
  igvIncluded           Boolean @default(false)
  detractionApplied     Boolean @default(false)
  detractionAmountCents Int @default(0)
  detractionConstancia  String?   // Número de constancia

  // Estado
  status                String @default("PENDING_VERIFICATION")  // PENDING_VERIFICATION, VERIFIED, REJECTED, RECONCILED
  verificationNotes     String?
  rejectionReason       String?

  // Conciliación contable
  reconciledAt          DateTime?
  reconciledById        String?
  accountingRef         String?   // Referencia contable

  // Auditoría
  registeredById        String?
  registeredAt          DateTime @default(now())

  metadata              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([paymentOrderId])
  @@index([installmentId])
  @@index([status])
  @@index([transactionDate])
}

//
// RESUMEN DE IMPUESTOS POR PERÍODO
//
model TaxSummary {
  id        String @id @default(cuid())
  centerId  String

  // Período
  periodType        String    // "MONTHLY", "QUARTERLY", "ANNUAL"
  periodYear        Int
  periodMonth       Int?      // 1-12 para mensual
  periodQuarter     Int?      // 1-4 para trimestral

  // IGV
  igvCollectedCents     Int @default(0)   // IGV cobrado a clientes
  igvPaidCents          Int @default(0)   // IGV pagado (crédito fiscal)
  igvBalanceCents       Int @default(0)   // Saldo a pagar/favor

  // Retenciones 4ta categoría
  retencion4taWithheldCents  Int @default(0)  // Total retenido a árbitros
  retencion4taPaidCents      Int @default(0)  // Pagado a SUNAT

  // Detracciones
  detractionReceivedCents    Int @default(0)  // Detracciones recibidas
  detractionPaidCents        Int @default(0)  // Detracciones efectuadas

  // Estado de declaración
  isDeclared        Boolean @default(false)
  declaredAt        DateTime?
  declarationNumber String?   // Número de PDT u otro

  // Estado de pago
  isPaid            Boolean @default(false)
  paidAt            DateTime?
  paymentRef        String?

  // Notas
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, periodType, periodYear, periodMonth])
  @@index([centerId])
  @@index([periodYear])
}

//
// CONFIGURACIÓN DE MIGRACIÓN/IMPORTACIÓN
//
model ImportBatch {
  id        String @id @default(cuid())
  centerId  String

  // Info del lote
  batchCode       String @unique
  description     String?
  sourceSystem    String?

  // Estadísticas
  totalRecords    Int @default(0)
  successCount    Int @default(0)
  errorCount      Int @default(0)
  skippedCount    Int @default(0)

  // Estado
  status          String @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  startedAt       DateTime?
  completedAt     DateTime?

  // Errores
  errorLog        Json?

  // Auditoría
  importedById    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([status])
}

// =============================================================================
// SYSTEM INTEGRATIONS - Configuraciones, API Keys, Servicios Externos
// =============================================================================

//
// INTEGRATION - CATEGORÍAS DE CONFIGURACIÓN
//
enum IntegrationType {
  EMAIL       // Configuración de correo (SMTP, SendGrid, etc.)
  SMS         // Servicios de SMS (Twilio, etc.)
  CALENDAR    // Google Calendar, Outlook, etc.
  MEETING     // Google Meet, Zoom, etc.
  STORAGE     // Google Drive, S3, etc.
  PAYMENT     // Pasarelas de pago
  AUTH        // OAuth providers
  AI          // OpenAI, Anthropic, etc.
  DOMAIN      // Configuración de dominios
  WEBHOOK     // Webhooks entrantes/salientes
  ANALYTICS   // Google Analytics, etc.
  CUSTOM      // Integraciones personalizadas
}

//
// INTEGRATION - CONFIGURACIONES ENCRIPTADAS
//
model SystemIntegration {
  id        String @id @default(cuid())
  centerId  String?

  // Identificación
  type        IntegrationType
  code        String          // Código único: "google-calendar", "smtp-email", etc.
  name        String          // Nombre visible: "Google Calendar"
  description String?

  // Estado
  isActive    Boolean @default(false)
  isConfigured Boolean @default(false)

  // Credenciales (ENCRIPTADAS - nunca se muestran completas)
  // Almacenamos las credenciales encriptadas en JSON
  credentials Json?   // { "apiKey": "encrypted...", "secret": "encrypted..." }

  // Configuración adicional (no sensible)
  settings    Json?   // { "webhookUrl": "...", "region": "...", etc. }

  // Metadatos
  lastTestedAt   DateTime?
  lastTestStatus String?   // "success", "failed", "unknown"
  lastTestError  String?

  // Para OAuth
  accessToken     String?  // Encriptado
  refreshToken    String?  // Encriptado
  tokenExpiresAt  DateTime?

  // Auditoría
  createdById     String?
  lastModifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, code])
  @@index([type])
  @@index([isActive])
}

//
// DOMAIN - CONFIGURACIÓN DE DOMINIOS Y SUBDOMINIOS
//
model DomainConfig {
  id        String @id @default(cuid())
  centerId  String

  // Dominio
  domain        String    // ejemplo: "caardpe.com"
  subdomain     String?   // ejemplo: "app" (para app.caardpe.com)
  fullDomain    String    // ejemplo: "app.caardpe.com" o "caardpe.com"

  // Tipo
  isPrimary     Boolean @default(false)
  isVerified    Boolean @default(false)

  // SSL
  sslEnabled    Boolean @default(true)
  sslExpiresAt  DateTime?

  // DNS
  dnsVerificationToken String?
  dnsVerifiedAt       DateTime?

  // Estado
  status        String @default("PENDING") // PENDING, VERIFIED, ACTIVE, INACTIVE, ERROR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fullDomain])
  @@index([centerId])
  @@index([status])
}

//
// SCHEDULED MEETINGS - Audiencias y Reuniones programadas
//
model ScheduledMeeting {
  id        String @id @default(cuid())
  centerId  String

  // Referencia al caso (opcional)
  caseId    String?
  case      Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  // Tipo de reunión
  type      String    // "AUDIENCIA", "REUNION", "CONFERENCIA", etc.
  title     String
  description String?

  // Programación
  startTime   DateTime
  endTime     DateTime
  timezone    String @default("America/Lima")

  // Ubicación
  isVirtual   Boolean @default(true)
  location    String?  // Ubicación física

  // Integración con servicios externos
  meetingProvider String?  // "GOOGLE_MEET", "ZOOM", "TEAMS"
  meetingUrl      String?  // URL de la reunión
  meetingId       String?  // ID externo de la reunión
  meetingPassword String?

  // Google Calendar
  googleCalendarEventId String?
  googleCalendarLink    String?

  // Participantes
  organizerId   String?
  organizer     User?  @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)

  // Estado
  status        String @default("SCHEDULED") // SCHEDULED, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED

  // Notificaciones
  reminderSent  Boolean @default(false)
  reminderSentAt DateTime?

  // Grabación
  recordingUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MeetingParticipant[]

  @@index([centerId])
  @@index([caseId])
  @@index([startTime])
  @@index([status])
}

//
// PARTICIPANTES DE REUNIONES
//
model MeetingParticipant {
  id        String @id @default(cuid())

  meetingId String
  meeting   ScheduledMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Participante (puede ser usuario del sistema o externo)
  userId    String?
  user      User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Para participantes externos
  name      String?
  email     String?
  phone     String?

  // Rol en la reunión
  role      String?   // "ARBITRO", "DEMANDANTE", "DEMANDADO", "ABOGADO", "SECRETARIA", "INVITADO"

  // Estado
  status    String @default("INVITED") // INVITED, CONFIRMED, DECLINED, ATTENDED, NO_SHOW

  // Notificaciones
  notifiedAt    DateTime?
  confirmedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, userId])
  @@unique([meetingId, email])
  @@index([meetingId])
  @@index([userId])
}

//
// NOTIFICATION TEMPLATES - Plantillas de notificación del centro
//
model NotificationTemplate {
  id        String @id @default(cuid())
  centerId  String?

  // Información básica
  name      String    // Nombre descriptivo
  code      String    // Código único (ej: TRASLADO_DEMANDA)
  type      String    // TRASLADO, ADMISION, RECHAZO, AUDIENCIA, LAUDO, RECORDATORIO, PAGO, etc.

  // Contenido para cada canal
  emailSubject    String?
  emailBody       String?   @db.Text
  emailHtmlBody   String?   @db.Text
  smsBody         String?   @db.VarChar(320)  // Limitado para SMS
  whatsappBody    String?   @db.Text

  // Variables disponibles (JSON array)
  availableVariables Json?  // ["{{caseNumber}}", "{{partyName}}", ...]

  // Estado
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false) // Plantilla por defecto del sistema

  // Metadata
  description String?
  category    String?   // Para agrupar plantillas

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, code])
  @@index([centerId])
  @@index([type])
  @@index([isActive])
}

//
// SYSTEM AUDIT LOG - Para cambios en configuraciones del sistema
//
model SystemAuditLog {
  id        String @id @default(cuid())

  // Acción
  action      String    // "CREATE", "UPDATE", "DELETE", "TEST", "ENABLE", "DISABLE"
  entityType  String    // "SystemIntegration", "DomainConfig", etc.
  entityId    String?

  // Detalles
  description String?
  changes     Json?     // { "field": { "old": "...", "new": "..." } }
  metadata    Json?

  // Información de seguridad
  ipAddress   String?
  userAgent   String?

  // Auditoría
  userId      String?
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

//
// CONFIGURACIÓN DEL SISTEMA
//
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================
// MÓDULOS COMERCIALES: CURSOS, TIENDA, LAUDOS
// =============================================

//
// ENUMS COMERCIALES
//

enum CourseModality {
  ONLINE
  PRESENCIAL
  HYBRID
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ENROLLED
  COMPLETED
  CANCELLED
}

enum ProductType {
  DIGITAL
  PHYSICAL
  SERVICE
}

enum OrderStatus {
  PENDING_PAYMENT
  ORDER_PAID
  PROCESSING
  SHIPPED
  DELIVERED
  ORDER_CANCELLED
  ORDER_REFUNDED
}

enum OrderItemType {
  COURSE
  PRODUCT
  LAUDO
  SUBSCRIPTION
}

enum CartItemType {
  CART_COURSE
  CART_PRODUCT
  CART_LAUDO
  CART_SUBSCRIPTION
}

enum LaudoAccessLevel {
  FREE
  PREMIUM
}

enum SubscriptionPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum SubscriptionStatus {
  SUB_ACTIVE
  SUB_EXPIRED
  SUB_CANCELLED
  SUB_PENDING_PAYMENT
}

enum LandingPageTemplate {
  COURSE_PROMO
  SERVICE_PROMO
  EVENT_PROMO
  CUSTOM
}

enum LandingPageStatus {
  LP_DRAFT
  LP_PUBLISHED
  LP_ARCHIVED
}

//
// CURSOS
//

model Course {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug          String
  title         String
  description   String?
  content       String?  // Rich text / HTML
  coverImage    String?

  modality      CourseModality @default(ONLINE)
  status        CourseStatus   @default(DRAFT)
  categoryId    String?

  // Precios
  isFree        Boolean  @default(false)
  priceCents    Int?     // null = gratis
  currency      String   @default("PEN")
  taxConfig     Json?    // {igv: bool, detraccion: bool, percepcion: bool}

  // Online
  lessons       CourseLesson[]

  // Presencial
  startDate     DateTime?
  endDate       DateTime?
  timezone      String   @default("America/Lima")
  location      String?
  maxCapacity   Int?
  currentEnrolled Int    @default(0)

  // Instructor
  instructorName  String?
  instructorBio   String?
  instructorImage String?

  // Meta
  durationHours Float?
  isFeatured    Boolean @default(false)

  enrollments   Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
  @@index([status])
}

model CourseLesson {
  id        String @id @default(cuid())
  courseId   String
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  content     String?
  videoUrl    String?
  sortOrder   Int     @default(0)
  durationMinutes Int?

  materials   CourseMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model CourseMaterial {
  id        String @id @default(cuid())
  lessonId  String
  lesson    CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  title     String
  fileUrl   String
  fileType  String?
  fileSize  Int?

  createdAt DateTime @default(now())

  @@index([lessonId])
}

model Enrollment {
  id        String @id @default(cuid())
  courseId   String
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status     EnrollmentStatus @default(PENDING_PAYMENT)
  paidAmountCents Int?
  currency   String @default("PEN")

  orderId    String?
  order      StoreOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  enrolledAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, userId])
  @@index([userId])
  @@index([status])
}

//
// TIENDA
//

model StoreProduct {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug          String
  title         String
  description   String?
  content       String?
  coverImage    String?
  images        Json?    // String[]

  type          ProductType @default(DIGITAL)
  categoryId    String?
  category      StoreCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Precios
  priceCents        Int
  comparePriceCents Int?       // Precio tachado
  currency          String     @default("PEN")
  taxConfig         Json?      // {igv: bool, detraccion: bool, percepcion: bool}

  // Inventario (físico)
  stock         Int?
  trackStock    Boolean @default(false)

  // Digital
  digitalFileUrl  String?
  digitalFileType String?

  // Servicio
  serviceDurationMinutes Int?
  serviceBookingUrl      String?

  // Envío (físico)
  weight           Float?
  requiresShipping Boolean @default(false)

  isPublished   Boolean @default(false)
  isFeatured    Boolean @default(false)

  orderItems    StoreOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
  @@index([type])
  @@index([categoryId])
  @@index([isPublished])
}

model StoreCategory {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug        String
  name        String
  description String?
  coverImage  String?
  sortOrder   Int     @default(0)

  products    StoreProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
}

//
// BIBLIOTECA DE LAUDOS
//

model Laudo {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug          String
  title         String
  summary       String?    // Resumen público (siempre visible)
  fullPdfUrl    String?    // PDF completo (solo con acceso)

  accessLevel   LaudoAccessLevel @default(FREE)
  priceCents    Int?       // Precio compra individual (null = no vendible individualmente)
  currency      String     @default("PEN")

  // Metadatos indexables para búsqueda
  year              Int?
  arbitrationType   String?  // comercial, construcción, minería, etc.
  subject           String?  // materia: contractual, laboral, societario, etc.
  claimAmountRange  String?  // e.g., "100000-500000" o "menor a 100000"
  result            String?  // estimado, desestimado, parcial, conciliado
  arbitratorCount   Int?     // 1 o 3
  isAnonymized      Boolean  @default(true)
  pageCount         Int?
  tags              Json?    // String[] tags adicionales

  categoryId    String?
  category      LaudoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  isPublished   Boolean @default(false)
  isFeatured    Boolean @default(false)
  downloadCount Int     @default(0)

  accesses      LaudoAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
  @@index([accessLevel])
  @@index([year])
  @@index([subject])
  @@index([isPublished])
}

model LaudoCategory {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug        String
  name        String
  description String?
  sortOrder   Int     @default(0)

  laudos      Laudo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
}

model LaudoSubscription {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  period    SubscriptionPeriod
  status    SubscriptionStatus @default(SUB_PENDING_PAYMENT)
  priceCents Int
  currency  String @default("PEN")

  startDate   DateTime?
  endDate     DateTime?
  autoRenew   Boolean @default(false)

  orderId     String?
  order       StoreOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model LaudoAccess {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  laudoId   String
  laudo     Laudo  @relation(fields: [laudoId], references: [id], onDelete: Cascade)

  grantedAt DateTime @default(now())
  expiresAt DateTime?
  grantType String   // PURCHASE, SUBSCRIPTION, ROLE_BASED, CASE_BASED

  orderId   String?

  @@unique([userId, laudoId])
  @@index([userId])
  @@index([laudoId])
}

model LaudoPackage {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  laudoCount    Int        // Cantidad de laudos incluidos
  priceCents    Int
  discountPercent Int      @default(0)
  currency      String     @default("PEN")
  isActive      Boolean    @default(true)
  validDays     Int        @default(365)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
}

//
// PERFILES DE ÁRBITROS
//

model ArbitratorProfile {
  id          String @id @default(cuid())
  registryId  String @unique
  registry    ArbitratorRegistry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  slug            String @unique
  displayName     String
  title           String?  // e.g., "Árbitro Especialista en Derecho Comercial"
  photoUrl        String?
  biography       String?  // Rich text
  education       Json?    // [{degree, institution, year}]
  experience      Json?    // [{position, organization, period}]
  publications    Json?    // [{title, publisher, year, url}]
  languages       Json?    // ["Español", "Inglés", "Portugués"]
  contactEmail    String?
  linkedinUrl     String?
  yearsExperience Int?
  laudosCount     Int      @default(0)

  isPublished     Boolean  @default(false)
  isFeatured      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
}

//
// LANDING PAGES
//

model LandingPage {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  slug            String
  title           String
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  template   LandingPageTemplate @default(CUSTOM)
  status     LandingPageStatus   @default(LP_DRAFT)

  // El contenido usa CmsSection vinculadas via landingPageId
  sections   LandingPageSection[]

  conversionGoal String?  // Texto del objetivo (e.g., "Inscripción al curso")
  targetUrl      String?  // URL de redirección post-conversión

  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  viewCount   Int       @default(0)
  conversionCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, slug])
  @@index([centerId])
  @@index([isPublished])
}

model LandingPageSection {
  id            String @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  type      CmsSectionType
  title     String?
  subtitle  String?
  content   Json?
  bgColor   String?
  textColor String?
  bgImage   String?
  padding   String?  @default("md")
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([landingPageId])
}

//
// CARRITO DE COMPRAS
//

model Cart {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  cart      Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  itemType   CartItemType
  courseId    String?
  productId  String?
  laudoId    String?

  quantity   Int    @default(1)
  priceCents Int
  currency   String @default("PEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

//
// ÓRDENES DE COMPRA
//

model StoreOrder {
  id          String @id @default(cuid())
  centerId    String
  center      Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  orderNumber String @unique  // ORD-2026-000001
  userId      String?
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Info invitado (si no tiene cuenta)
  guestEmail  String?
  guestName   String?
  guestPhone  String?

  status      OrderStatus @default(PENDING_PAYMENT)

  // Totales
  subtotalCents     Int
  igvCents          Int     @default(0)
  detraccionCents   Int     @default(0)
  percepcionCents   Int     @default(0)
  shippingCents     Int     @default(0)
  totalCents        Int
  currency          String  @default("PEN")

  // Envío (productos físicos)
  shippingAddress   Json?
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  // Pago
  paymentProvider   String?   // CULQI, YAPE, TRANSFERENCIA
  paymentStatus     String?   @default("PENDING")
  culqiChargeId     String?
  culqiRaw          Json?
  paidAt            DateTime?

  // Items y relaciones
  items             StoreOrderItem[]
  enrollments       Enrollment[]
  laudoSubscriptions LaudoSubscription[]

  adminNotes        String?
  customerNotes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model StoreOrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemType   OrderItemType
  courseId    String?
  productId  String?
  product    StoreProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  laudoId    String?

  title      String   // Snapshot del nombre
  quantity   Int
  unitPriceCents Int
  totalCents Int
  currency   String   @default("PEN")
  taxBreakdown Json?  // {igv, detraccion, percepcion}

  // Descarga digital
  digitalDownloadUrl String?
  downloadCount      Int     @default(0)

  createdAt DateTime @default(now())

  @@index([orderId])
}

//
// CONFIGURACIÓN TRIBUTARIA
//

model CommerceTaxConfig {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  name              String   // e.g., "IGV Productos", "Detracción Servicios"
  type              TaxType
  rate              Float    // Porcentaje decimal: 0.18 = 18%
  isActive          Boolean  @default(true)
  thresholdCents    Int?     // Monto mínimo para aplicar (en céntimos)
  appliesToProducts Boolean  @default(true)
  appliesToCourses  Boolean  @default(true)
  appliesToLaudos   Boolean  @default(true)
  appliesToServices Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([type])
}

//
// PAGOS LIBRES
//

model FreePayment {
  id        String @id @default(cuid())
  centerId  String
  center    Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    String?  // Opcional: vincular a un expediente

  concept       String
  description   String?
  amountCents   Int
  currency      String  @default("PEN")
  taxBreakdown  Json?   // {subtotal, igv, detraccion, percepcion, total}

  status            String  @default("PENDING") // PENDING, PAID, CANCELLED
  paymentProvider   String?
  culqiChargeId     String?
  paidAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([userId])
  @@index([caseId])
}
