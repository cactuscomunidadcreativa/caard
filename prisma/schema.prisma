//
// ÓRDENES DE PAGO
//
model PaymentOrder {
  id        String @id @default(cuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  orderNumber   String @unique // OP-2026-000001
  concept       PaymentConcept
  description   String

  // Montos
  amountCents   Int
  igvCents      Int @default(0)
  totalCents    Int
  currency      String @default("PEN")

  // Fechas
  issuedAt      DateTime @default(now())
  dueAt         DateTime
  paidAt        DateTime?

  // Estado
  status        PaymentOrderStatus @default(PENDING)

  // Pagos asociados
  paymentId     String?

  // Bloqueo automático
  blocksCase    Boolean @default(true)

  // Devolución
  refundedAt    DateTime?
  refundAmount  Int?
  refundReason  String?

  // Metadata
  metadata      Json?

  // Auditoría
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([dueAt])
  @@index([concept])
